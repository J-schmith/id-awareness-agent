# =============================================================================
# I&D Awareness Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key for Claude (research & drafting)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/id_awareness_agent

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── Optional ─────────────────────────────────────────────────────────────────

# Base URL for NextAuth (defaults to http://localhost:3000 in dev)
NEXTAUTH_URL=http://localhost:3000

# AWS credentials for SES email sending
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# Verified sender address in AWS SES
SES_FROM_EMAIL=noreply@company.com
